{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "sebastian": {
      "mode": "primary",
      "description": "Senior Architect - minimal config",
      "temperature": 0.1,
      "prompt": "{file:./prompts/sebastian.txt}",
      "permission": {
        "read": "allow",
        "write": "allow",
        "edit": "allow",
        "bash": "allow",
        "skill": "allow",
        "task": {
          "*": "allow"
        },
        "webfetch": "allow",
        "delegate": "allow",
        "delegation_read": "allow",
        "delegation_list": "allow"
      },
      "instructions": [
        "~/.config/opencode/AGENTS.md",
        "~/.config/opencode/security_rules.md"
      ]
    }
  },
  "autoupdate": true,
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 60000
  },
  "default_agent": "sebastian",
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true
    },
    "engram": {
      "command": [
        "/opt/homebrew/bin/engram",
        "mcp",
        "--tools=agent"
      ],
      "enabled": true,
      "type": "local",
      "environment": {
        "ENGRAM_CLOUD_AUTOSYNC": "1",
        "ENGRAM_CLOUD_TOKEN": "engram-local-token-32chars-xxxxx",
        "ENGRAM_CLOUD_SERVER": "http://100.75.235.85:18080"
      }
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ],
      "enabled": false
    },
    "pencil": {
      "command": [
        "/Applications/Pencil.app/Contents/Resources/app.asar.unpacked/out/mcp-server-darwin-arm64",
        "--app",
        "desktop"
      ],
      "enabled": false,
      "type": "local"
    }
  },
  "permission": {
    "bash": {
      "*": "allow",
      "git commit*": "ask",
      "git push*": "ask",
      "git rebase*": "ask",
      "git reset --hard*": "ask",
      "git clean*": "ask",
      "git checkout -f*": "ask",
      "rm -rf *": "ask",
      "rm -f *": "ask"
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/.ssh/**": "deny",
      "**/id_*": "deny",
      "**/.git/hooks/**": "deny",
      "**/.git/objects/**": "deny",
      "**/.DS_Store": "deny",
      "**/Thumbs.db": "deny",
      "**/.svn/**": "deny",
      "**/.hg/**": "deny",
      "**/CVS/**": "deny",
      "**/*.pem": "deny",
      "**/*.key": "deny",
      "**/*.ppk": "deny",
      "**/*.p12": "deny",
      "**/*.pfx": "deny",
      "**/*.pvk": "deny",
      "**/secrets/**": "deny",
      "**/credentials.json": "deny"
    }
  },
  "plugin": [
    "@warp-dot-dev/opencode-warp",
    "@tarquinen/opencode-dcp@latest",
    "opencode-worktree@latest"
  ]
}
